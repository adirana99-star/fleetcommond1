# ---- FleetCommand web/mobile app environment ----
# These EXPO_PUBLIC_* values are baked into the build at compile time.

# Production: point the app at your live backend API domain.
EXPO_PUBLIC_ENVIRONMENT=production
EXPO_PUBLIC_API_BASE_URL=https://api.fleetmind.org

# Local backend example:
# EXPO_PUBLIC_ENVIRONMENT=development
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
