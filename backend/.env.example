# ---- FleetCommand backend environment ----
# Copy this file to backend/.env for local dev, or set these as environment
# variables in your host's dashboard (Render/Railway/VPS) for production.

# MongoDB Atlas connection string (use a dedicated DB user, NOT the cluster admin)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority&appName=Cluster0

# Port the API listens on. Most hosts inject their own PORT automatically.
PORT=4000

# Allowed browser origins for CORS. Comma-separate multiple domains.
# Production example: https://app.fleetmind.org,https://fleetmind.org
# Local dev example:  http://localhost:8084
CORS_ORIGIN=https://app.fleetmind.org,https://fleetmind.org

# Set to true when running behind a proxy/load balancer (Render, Railway, Nginx).
TRUST_PROXY=true

# Strong random secret used to sign JWTs (>= 32 chars recommended).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-strong-random-secret

JWT_EXPIRES_IN=7d

# sha256 hash of the platform super-admin password.
# Generate: node -e "console.log(require('crypto').createHash('sha256').update('YOUR_PASSWORD').digest('hex'))"
PLATFORM_PASSWORD_HASH=

# Require a valid JWT for the /fleet/sync endpoint (recommended: true in production).
REQUIRE_AUTH_FOR_SYNC=true